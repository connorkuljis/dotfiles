#!/usr/bin/env bash

set -euo pipefail

RED='\e[0;31m'
GREEN='\e[0;32m'
BLUE='\e[0;34m'
RESET='\e[0m'

if [[ ! "$(command -v tailscale)" ]]; then
	echo -e "${RED}× error: tailscale not installed.${RESET}"
	exit 1
fi

operator="${USER}"

(
	set -x
	sudo tailscale down
	sudo tailscale up \
		--reset \
		--accept-routes=false \
		--operator="${operator}"
)

echo -e "\n${BLUE}● waiting: tailscale is reconnecting${RESET}"

if ! tailscale wait --timeout=30s; then
	echo -e "${RED}× error: tailscale did not connect within 30 seconds.${RESET}"
	exit 1
fi

echo -e "${GREEN}● ok: tailscale connected${RESET}"
echo -e "${BLUE}● ip:${RESET}"
tailscale ip
